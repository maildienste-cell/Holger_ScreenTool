{
  "name": "desktop-mini-agent",
  "version": "1.1.5",
  "description": "Desktop Mini Agent (Antigravity)",
  "author": "Holger",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build-app.js && tccutil reset Accessibility com.electron.desktop-mini-agent || true",
    "build:packager": "electron-packager . --overwrite --platform=darwin --arch=arm64 --icon=robotTemplate.png --extend-info=Info.plist --prune=true --out=release-builds"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "dompurify": "^3.4.1",
    "form-data": "^4.0.5",
    "marked": "^18.0.2",
    "node-fetch": "^2.7.0",
    "node-llama-cpp": "^3.1.1",
    "openclaw": "^2026.5.28",
    "pdf-parse": "^1.1.1"
  }
}
